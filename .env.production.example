# TAKTKRONE-I Production Environment Configuration
# This file contains production-ready environment variables
# Copy and modify as needed for your deployment

# ============================================
# API Keys (Production)
# ============================================

# Transit Operator APIs
MTA_API_KEY=${MTA_PROD_API_KEY}
MBTA_API_KEY=${MBTA_PROD_API_KEY}
WMATA_API_KEY=${WMATA_PROD_API_KEY}
BART_API_KEY=${BART_PROD_API_KEY}
TFL_APP_ID=${TFL_PROD_APP_ID}
TFL_APP_KEY=${TFL_PROD_APP_KEY}

# Model and Infrastructure
HUGGINGFACE_TOKEN=${HF_PROD_TOKEN}
WANDB_API_KEY=${WANDB_PROD_KEY}
OPENAI_API_KEY=${OPENAI_PROD_KEY}

# ============================================
# Production Infrastructure
# ============================================

# Model Configuration
MODEL_PATH=/models/taktkrone-production-v1
MODEL_CACHE_DIR=/cache/models
MAX_SEQUENCE_LENGTH=4096
BATCH_SIZE=4
CONCURRENT_REQUESTS=16

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
TIMEOUT=30
KEEPALIVE=65

# Database Configuration
DATABASE_URL=postgresql://taktkrone:${DB_PASSWORD}@db.taktkrone.ai:5432/taktkrone_prod
REDIS_URL=redis://cache.taktkrone.ai:6379/0

# Storage Configuration
AWS_S3_BUCKET=taktkrone-production
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_PROD_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${AWS_PROD_SECRET_KEY}

# Monitoring and Logging
LOG_LEVEL=INFO
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true

# Security
AUTH_ENABLED=true
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=https://taktkrone.ai,https://dashboard.taktkrone.ai
RATE_LIMIT=100req/min

# Safety and Compliance
SAFETY_GUARDS_ENABLED=true
AUDIT_LOGGING_ENABLED=true
DATA_RETENTION_DAYS=2555  # 7 years
ENCRYPTION_ENABLED=true

# ============================================
# Deployment Configuration
# ============================================

# Kubernetes
K8S_NAMESPACE=taktkrone-prod
K8S_CLUSTER=production-cluster
HELM_RELEASE=taktkrone-v1

# Health Checks
HEALTH_CHECK_INTERVAL=30
READINESS_PROBE_PATH=/ready
LIVENESS_PROBE_PATH=/health

# Auto-scaling
MIN_REPLICAS=2
MAX_REPLICAS=10
CPU_TARGET=70
MEMORY_TARGET=80
