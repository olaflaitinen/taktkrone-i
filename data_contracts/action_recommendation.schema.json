{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metrolm.org/schemas/action_recommendation.v1.0.0.json",
  "title": "ActionRecommendation",
  "description": "Structured output schema for OCC action recommendations from the model",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "timestamp",
    "operator",
    "request_context",
    "analysis",
    "recommendations",
    "uncertainties",
    "safety_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique recommendation identifier"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When recommendation was generated"
    },
    "operator": {
      "type": "string",
      "description": "Transit operator code"
    },
    "request_context": {
      "type": "object",
      "description": "Context of the original request",
      "required": ["query", "query_type"],
      "properties": {
        "query": {
          "type": "string",
          "description": "Original user query"
        },
        "query_type": {
          "type": "string",
          "enum": [
            "situation_summary",
            "diagnosis",
            "recovery_plan",
            "headway_regulation",
            "turnback_decision",
            "conflict_resolution",
            "information_request"
          ]
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_window": {
          "type": "object",
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "analysis": {
      "type": "object",
      "description": "Situational analysis",
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Concise situation summary"
        },
        "root_cause": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Most likely root cause"
            },
            "confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "alternatives": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "cause": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "impact_assessment": {
          "type": "object",
          "properties": {
            "affected_lines": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "affected_stations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "estimated_passengers_impacted": {
              "type": "integer",
              "minimum": 0
            },
            "average_delay_minutes": {
              "type": "number"
            }
          }
        },
        "network_state": {
          "type": "object",
          "properties": {
            "current_headways": {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            },
            "train_positions": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "constraints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Ranked list of recommended actions",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action_id", "action_type", "priority", "rationale"],
        "properties": {
          "action_id": {
            "type": "string",
            "description": "Unique action identifier"
          },
          "action_type": {
            "type": "string",
            "enum": [
              "hold_train",
              "express_operation",
              "short_turn",
              "skip_stop",
              "increase_frequency",
              "reduce_frequency",
              "dispatch_additional_train",
              "verify_infrastructure",
              "coordinate_with_maintainer",
              "passenger_communication",
              "monitor_situation",
              "prepare_contingency"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "description": "Priority rank (1=highest)"
          },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "short_term", "medium_term", "contingency"]
          },
          "title": {
            "type": "string",
            "description": "Short action title"
          },
          "rationale": {
            "type": "string",
            "description": "Why this action is recommended"
          },
          "execution": {
            "type": "object",
            "properties": {
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "estimated_duration_minutes": {
                "type": "number"
              },
              "resources_required": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "expected_outcome": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "metrics": {
                "type": "object",
                "additionalProperties": true
              },
              "time_to_effect_minutes": {
                "type": "number"
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence in effectiveness of this action"
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Potential risks or downsides"
          },
          "requires_approval": {
            "type": "boolean",
            "description": "Whether this requires supervisor/manager approval"
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "description": "Explicit uncertainty factors",
      "items": {
        "type": "object",
        "required": ["factor", "impact"],
        "properties": {
          "factor": {
            "type": "string",
            "description": "Source of uncertainty"
          },
          "impact": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Impact on recommendation reliability"
          },
          "mitigation": {
            "type": "string",
            "description": "How to reduce this uncertainty"
          }
        }
      }
    },
    "safety_notes": {
      "type": "array",
      "description": "Safety considerations and warnings",
      "items": {
        "type": "string"
      }
    },
    "retrieval_references": {
      "type": "array",
      "description": "Retrieved documents/facts used in reasoning",
      "items": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "relevance_score": {
            "type": "number"
          },
          "snippet": {
            "type": "string"
          }
        }
      }
    },
    "model_metadata": {
      "type": "object",
      "description": "Model execution metadata",
      "properties": {
        "model_name": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "inference_time_ms": {
          "type": "number"
        },
        "tokens_generated": {
          "type": "integer"
        },
        "temperature": {
          "type": "number"
        },
        "rag_enabled": {
          "type": "boolean"
        }
      }
    },
    "human_oversight": {
      "type": "object",
      "description": "Guidance for human review",
      "properties": {
        "review_required": {
          "type": "boolean"
        },
        "review_priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "urgent"]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "examples": [
    {
      "id": "rec_20260327_001",
      "schema_version": "1.0.0",
      "timestamp": "2026-03-27T17:30:45Z",
      "operator": "mta_nyct",
      "request_context": {
        "query": "Line 1 southbound trains are bunching. What should I do?",
        "query_type": "headway_regulation",
        "lines": ["1"],
        "time_window": {
          "start": "2026-03-27T17:00:00Z",
          "end": "2026-03-27T17:30:00Z"
        }
      },
      "analysis": {
        "summary": "Three Line 1 southbound trains are bunched within 2 minutes between 96th St and Times Square. Bunching appears caused by signal delay at 96th St compounded by crowding.",
        "root_cause": {
          "primary": "signal_delay_with_demand_surge",
          "confidence": 0.78,
          "alternatives": [
            {
              "cause": "operator_unavailability",
              "confidence": 0.15
            }
          ]
        },
        "severity": "medium",
        "impact_assessment": {
          "affected_lines": ["1"],
          "affected_stations": ["96th St", "86th St", "79th St", "72nd St", "Times Square"],
          "estimated_passengers_impacted": 3500,
          "average_delay_minutes": 12.5
        }
      },
      "recommendations": [
        {
          "action_id": "act_001",
          "action_type": "hold_train",
          "priority": 1,
          "urgency": "immediate",
          "title": "Hold leading train at 42nd St for 4 minutes",
          "rationale": "Creates gap behind held train, allowing trailing bunch to spread naturally while held train absorbs demand",
          "execution": {
            "steps": [
              "Contact operator of leading train (currently approaching 42nd St)",
              "Instruct 4-minute hold at 42nd St",
              "Monitor trailing train spacing",
              "Release after 4 minutes or when gap reaches 5 minutes"
            ],
            "estimated_duration_minutes": 4,
            "resources_required": ["radio_contact_with_operator"]
          },
          "expected_outcome": {
            "description": "Restore 5-6 minute headways within 15-20 minutes",
            "metrics": {
              "target_headway_minutes": 5.5,
              "time_to_restoration_minutes": 18
            },
            "time_to_effect_minutes": 20
          },
          "confidence": 0.82,
          "risks": [
            "Platform crowding at 42nd St during hold",
            "Operator discomfort if hold extends beyond 4 minutes"
          ],
          "requires_approval": false
        },
        {
          "action_id": "act_002",
          "action_type": "verify_infrastructure",
          "priority": 2,
          "urgency": "immediate",
          "title": "Verify signal status at 96th St with maintainer",
          "rationale": "Confirming signal resolution prevents recurrence of bunching pattern",
          "confidence": 0.95,
          "requires_approval": false
        }
      ],
      "uncertainties": [
        {
          "factor": "Actual cause may be rolling stock issue, not signal",
          "impact": "medium",
          "mitigation": "Check vehicle diagnostics for leading train"
        },
        {
          "factor": "Platform crowding levels at downstream stations unknown",
          "impact": "low",
          "mitigation": "Request station agent reports"
        }
      ],
      "safety_notes": [
        "Monitor platform crowding at 42nd St during hold",
        "Ensure held train operator is kept informed",
        "Do not extend hold beyond 5 minutes without supervisor approval"
      ],
      "retrieval_references": [
        {
          "document_id": "proc_headway_regulation_v2",
          "title": "Headway Regulation Procedures - Section 4.2",
          "relevance_score": 0.94,
          "snippet": "For bunching scenarios, holding the leading train is preferred..."
        }
      ],
      "model_metadata": {
        "model_name": "taktkrone-i-v0.1",
        "model_version": "0.1.0",
        "inference_time_ms": 1247,
        "tokens_generated": 312,
        "temperature": 0.7,
        "rag_enabled": true
      },
      "human_oversight": {
        "review_required": false,
        "review_priority": "medium",
        "review_notes": [
          "Standard headway regulation scenario",
          "Recommendation aligns with procedure manual"
        ]
      }
    }
  ]
}
