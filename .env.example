# TAKTKRONE-I Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# API Keys
# ============================================

# MTA API Key (obtain from https://api.mta.info/)
MTA_API_KEY=your_mta_api_key_here

# MBTA API Key (obtain from https://api-v3.mbta.com/)
MBTA_API_KEY=your_mbta_api_key_here

# WMATA API Key (obtain from https://developer.wmata.com/)
WMATA_API_KEY=your_wmata_api_key_here

# BART API Key (obtain from https://www.bart.gov/schedules/developers/api)
BART_API_KEY=your_bart_api_key_here

# TfL Application ID and Key (obtain from https://api-portal.tfl.gov.uk/)
TFL_APP_ID=your_tfl_app_id_here
TFL_APP_KEY=your_tfl_app_key_here

# ============================================
# Hugging Face
# ============================================

# Hugging Face token for model downloads (optional for public models)
HUGGINGFACE_TOKEN=your_hf_token_here

# ============================================
# Experiment Tracking
# ============================================

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=taktkrone
WANDB_ENTITY=your_wandb_entity_here

# MLflow (if using self-hosted)
MLFLOW_TRACKING_URI=http://localhost:5000

# ============================================
# Storage and Database
# ============================================

# Data storage directory
DATA_DIR=./data

# Model storage directory
MODEL_DIR=./models

# Results storage directory
RESULTS_DIR=./results

# Vector database for RAG (if using Qdrant server)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ============================================
# Serving Configuration
# ============================================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Enable RAG retrieval
ENABLE_RAG=true

# Enable safety guardrails
ENABLE_GUARDRAILS=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Model Configuration
# ============================================

# Default base model to use
DEFAULT_BASE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Device (cuda, cpu, mps)
DEVICE=cuda

# Precision (fp16, bf16, fp32)
PRECISION=fp16

# ============================================
# Training Configuration
# ============================================

# Number of training epochs
NUM_EPOCHS=3

# Batch size
BATCH_SIZE=4

# Learning rate
LEARNING_RATE=2e-5

# Gradient accumulation steps
GRADIENT_ACCUMULATION_STEPS=8

# ============================================
# Rate Limiting
# ============================================

# Rate limit for API requests (requests per minute)
API_RATE_LIMIT=60

# Rate limit for public feeds (requests per minute)
FEED_RATE_LIMIT=10

# ============================================
# Feature Flags
# ============================================

# Enable synthetic data generation
ENABLE_SYNTHESIS=true

# Enable caching
ENABLE_CACHE=true

# Cache TTL in seconds
CACHE_TTL=300

# ============================================
# Development
# ============================================

# Debug mode
DEBUG=false

# Verbose logging
VERBOSE=false
